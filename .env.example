# AIOX Studio — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Ollama LLM ────────────────────────────────────────────────
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_TIMEOUT_SECONDS=8
OLLAMA_TEXT_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_TEXT_FAST_MODEL=qwen3:4b-instruct-2507-q4_K_M
OLLAMA_TEXT_QUALITY_MODEL=qwen2.5:14b-instruct-q4_K_M
OLLAMA_VISION_MODEL=qwen3-vl:4b-instruct-q4_K_M

# Keep-alive per tier (how long Ollama keeps model loaded)
OLLAMA_KEEP_ALIVE_TEXT=8m
OLLAMA_KEEP_ALIVE_FAST=4m
OLLAMA_KEEP_ALIVE_QUALITY=0
OLLAMA_KEEP_ALIVE_VISION=0

# Timeouts per task type (seconds)
OLLAMA_TIMEOUT_FAST_SECONDS=8
OLLAMA_TIMEOUT_PLAN_SECONDS=14
OLLAMA_TIMEOUT_QUALITY_SECONDS=45
OLLAMA_TIMEOUT_VISION_SECONDS=70
OLLAMA_RETRY_TIMEOUT_SECONDS=22

# ── LLM Routing ──────────────────────────────────────────────
# AIOX_LLM_FORCE_MODEL=         # Force a specific model for all tasks
AIOX_LLM_ROUTING_MODE=auto       # auto | fast | quality
AIOX_LLM_CONFIDENCE_THRESHOLD=0.70
AIOX_LLM_QUALITY_FALLBACK_MODE=explicit  # auto | explicit | off
# AIOX_LLM_DISABLE_QUALITY_FALLBACK=0
# AIOX_LLM_DEBUG=0

# ── Pipeline ─────────────────────────────────────────────────
AIOX_AUTO_APPROVE=0               # 1 = skip director approval prompt
AIOX_REMOTION_RENDER_MODE=auto    # auto | direct | cli
AIOX_REMOTION_CLI_TIMEOUT_SECONDS=45
